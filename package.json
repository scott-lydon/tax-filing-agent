{
  "name": "tax-filing-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx --env-file-if-exists=.env watch server/index.ts",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "tsx --env-file-if-exists=.env server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"server/**/*.ts\" \"tools/**/*.ts\" \"guardrails/**/*.ts\" \"tax/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@fastify/static": "^8.0.4",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.2.1",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.0.4"
  }
}
